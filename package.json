{
  "name": "gchat",
  "version": "0.1.5",
  "description": "Multi-account WhatsApp Web for macOS",
  "main": "out/main/index.js",
  "author": "internal",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --mac -c.directories.output=$HOME/.gchat-build/dist",
    "build:dir": "electron-vite build && electron-builder --mac --dir -c.directories.output=$HOME/.gchat-build/dist",
    "release": "electron-vite build && electron-builder --mac --publish always -c.directories.output=$HOME/.gchat-build/dist",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
